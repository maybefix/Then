{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Then",
  "version": "0.3.2",
  "identifier": "local.then",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Then",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../THIRD_PARTY_LICENSES/NotoCJK-OFL.txt": "THIRD_PARTY_LICENSES/NotoCJK-OFL.txt"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
