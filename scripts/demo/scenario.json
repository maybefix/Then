      "zoom": 1.08,
      "lead": 0.6,
      "hold": 1.0,
      "tail": 0.6,
      "afterMs": 2400
    },
    {
      "type": "click",
      "target": { "css": ".referenceCard button[aria-label=\"ピン留め\"]" },
      "label": "資料をピン留め",
      "afterMs": 800
    },
    {
      "type": "click",
      "target": { "css": ".referenceCard button[aria-label=\"閉じる\"]" },
      "label": "資料ポップアップを閉じる",
      "afterMs": 700
    },

    {
      "type": "click",
      "target": { "aria": "設定" },
      "label": "設定を開く",
      "afterMs": 1400
    },
    {
      "type": "click",
      "target": { "aria": "閉じる", "last": true },
      "label": "設定を閉じる",
      "afterMs": 700
    },

    {
      "type": "click",
      "target": { "aria": "チェックポイント" },
      "label": "チェックポイントを開く",
      "afterMs": 1300
    },
    {
      "type": "click",
      "target": { "text": "＋ 保存点を作成", "role": "button" },
      "label": "保存点を作成",
      "afterMs": 600
    },
    {
      "type": "type",
      "target": { "placeholder": "例: 終盤改稿前" },
      "text": "第一章プロット作成後",
      "label": "保存点タイトルを入力",
      "animate": true,
      "charDelay": 55,
      "afterMs": 300
    },
    {
      "type": "type",
      "target": { "placeholder": "例: 終盤の分岐前。会話のテンポを試す" },
      "text": "本文・Idea・Plotをまとめて保存",
      "label": "保存点メモを入力",
      "animate": true,
      "charDelay": 45,
      "afterMs": 350
    },
    {
      "type": "click",
      "target": { "text": "作成", "role": "button" },
      "label": "チェックポイントを確定",
      "afterMs": 1700
    },
    {
      "type": "assert",
      "target": { "css": ".checkpointSnapshotSelect" },
      "label": "作成した保存点を確認",
      "afterMs": 700
    },
    {
      "type": "click",
      "target": { "text": "本文へ戻る", "role": "button" },
      "label": "本文へ戻る",
      "afterMs": 800
    },

    {
      "type": "click",
      "target": { "text": "エクスポート", "role": "tab" },
      "label": "エクスポート画面を開く",
      "afterMs": 2600
    },
    {
      "type": "clickIfPresent",
      "target": { "text": "↻ プレビュー更新", "role": "button" },
      "label": "組版プレビューを更新",
      "afterMs": 3000
    },
    {
      "type": "click",
      "target": { "text": "本文", "role": "tab" },
      "label": "本文画面へ戻る",
      "afterMs": 1200
    },
    { "type": "wait", "ms": 1000 }
