    {
      "type": "click",
      "target": { "text": "フォルダを開く", "role": "menuitem" },
      "label": "プロジェクトフォルダを開く",
      "afterMs": 700
    },
    {
      "type": "nativeFolderDialog",
      "path": "${DEMO_WORKSPACE}",
      "label": "Windows のフォルダ選択",
      "afterMs": 2600
    },

    {
      "type": "editorAppend",
      "target": { "css": "[contenteditable=\"true\"]" },
