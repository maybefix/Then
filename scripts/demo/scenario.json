      "label": "本文に新しい場面を執筆",
      "charDelay": 70,
      "afterMs": 1400
    },
    {
      "type": "shortcut",
      "key": "f",
      "ctrl": true,
      "label": "本文検索を開く",
      "afterMs": 500
    },
    {
      "type": "type",
      "target": { "aria": "検索語句" },
      "text": "旅人",
      "label": "本文から旅人を検索",
      "animate": true,
      "charDelay": 90,
      "afterMs": 700
    },
    {
      "type": "click",
      "target": { "aria": "次の一致" },
      "label": "次の検索結果",
      "afterMs": 650
    },
    {
      "type": "click",
      "target": { "css": ".editorFindPopover button[aria-label=\"閉じる\"]" },
