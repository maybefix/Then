      "lead": 0.6,
      "hold": 1.0,
      "tail": 0.6,
      "afterMs": 2400
    },

    {
      "type": "click",
      "target": { "aria": "資料" },
      "label": "資料を開く",
      "afterMs": 700
    },
    {
      "type": "click",
